# Database connection string for Neon/Postgres.
# In Vercel, this is usually provided automatically when you attach a Postgres database.
POSTGRES_URL="postgres://user:password@host/dbname?sslmode=require"

# Optional one-time bootstrap admin for non-interactive deployments.
# If omitted, the app will show the first-run setup form until a superadmin is created.
BOOTSTRAP_ADMIN_USERNAME="admin"
BOOTSTRAP_ADMIN_PASSWORD="ChangeMeToAStrongPassword"
BOOTSTRAP_ADMIN_DISPLAY_NAME="Super Admin"
